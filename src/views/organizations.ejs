<%- include('partials/header') %>

    <h1>
        <%= title %>
    </h1>
    <p class="page-intro">Here are a few of our partner organizations:</p>

    <ul class="card-grid">
        <% organizations.forEach(organization=> { %>
            <li class="card">
                <img class="card__logo" src="/images/<%= organization.logo_filename %>"
                    alt="<%= organization.name %> logo">
                <p class="card__name">
                    <%= organization.name %>
                </p>
                <p class="card__contact"><a href="mailto:<%= organization.contact_email %>">
                        <%= organization.contact_email %>
                    </a></p>
            </li>
            <% }); %>
    </ul>

    <%- include('partials/footer') %>