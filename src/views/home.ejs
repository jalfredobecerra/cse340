        <a class="button" href="/organizations">Explore Partner Organizations</a>
    </div>
    <div class="hero__media">
        <img src="/images/cse340-service-network.png" alt="CSE 340 Service Network logo">
    </div>
</section>

<%- include('partials/footer') %>