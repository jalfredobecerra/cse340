<%- include('partials/header') %>

<section class="hero">
    <div class="hero__copy">
        <span class="hero__eyebrow">CSE 340 Service Network</span>
        <h1>
            <%= title %>
        </h1>
        <h2 style="color:#fff; margin-top:0; font-size:1.25rem; font-weight:600;">Welcome to the CSE 340 Service
            Network!</h2>
